    "class Solution:\n",
    "    def kthFactor(self, n: int, k: int) -> int:\n",
    "        count=0\n",
    "        n=10\n",
    "        for i in range(1,n+1,1):\n",
    "            if n%i==0:\n",
    "                count+=1\n",
    "            if count==k:\n",
    "                return i \n",
    "        return -1  \n",
    "c1=Solution()\n",
    "print(c1.kthFactor(100,3))"
   ]
  }
 ],
